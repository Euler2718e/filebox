<UserControl x:Class="FileBox.FileRowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MouseEnter="OnMouseEnter"
             MouseLeave="OnMouseLeave"
             MouseMove="OnMouseMove"
             PreviewMouseLeftButtonDown="OnPreviewMouseDown">

    <!--
        Mirrors FileRowView in ShelfView.swift.

        .padding(.horizontal, 6)         → Margin="6,1" on outer Border
        .padding(.horizontal, 10)        → Margin on inner content
        .padding(.vertical, 6)           → Padding on inner Grid
        Hover background opacity 0.06    → #0FFFFFFF
        xmark.circle.fill (SF Symbols)   → drawn with Ellipse + Path in RemoveBtn
        .truncationMode(.middle)         → TextTrimming=CharacterEllipsis (WPF has no middle-trim)
        .onDrag { NSItemProvider(url) }  → DoDragDrop with FileDrop DataObject (see code-behind)
    -->

    <Border x:Name="RowBg"
            CornerRadius="8"
            Background="Transparent"
            Margin="6,1">
        <Grid Margin="10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- File / URL icon (22×22) -->
            <Image x:Name="IconImage"
                   Grid.Column="0"
                   Width="22" Height="22"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- File name — end-truncated (closest WPF equivalent to middle truncation) -->
            <TextBlock x:Name="NameText"
                       Grid.Column="2"
                       FontSize="12"
                       Foreground="White"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"/>

            <!-- Remove button — visible on hover, mirrors xmark.circle.fill palette icon -->
            <Button x:Name="RemoveBtn"
                    Grid.Column="3"
                    Width="18" Height="18"
                    Margin="6,0,0,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Cursor="Hand"
                    Opacity="0"
                    Click="RemoveBtn_Click"
                    MouseLeftButtonDown="StopBubble">
                <Grid Width="14" Height="14">
                    <!-- Circle fill — Color.white.opacity(0.12) -->
                    <Ellipse Fill="#1EFFFFFF"/>
                    <!-- X stroke — Color.white.opacity(0.45) -->
                    <Path Data="M4,4 L10,10 M10,4 L4,10"
                          Stroke="#73FFFFFF"
                          StrokeThickness="1.6"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"/>
                </Grid>
            </Button>

        </Grid>
    </Border>

</UserControl>
